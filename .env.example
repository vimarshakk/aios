# AIOS Environment Variables

# Gateway Configuration
AIOS_GATEWAY_PORT=8080
AIOS_ORCHESTRATOR_PORT=8081
AIOS_MCP_PORT=8082

# Logging
AIOS_LOG_LEVEL=info
AIOS_LOG_FORMAT=json

# LLM Providers
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OLLAMA_BASE_URL=http://localhost:11434

# Vector Store
VECTOR_STORE_PATH=./data/vector_store
VECTOR_STORE_DIMENSION=1536

# Memory
MEMORY_BACKEND=sqlite
MEMORY_SQLITE_PATH=./data/memory.db

# Security
AIOS_SECRET_KEY=your_secret_key_here
AIOS_JWT_ALGORITHM=HS256
AIOS_JWT_EXPIRATION_HOURS=24

# Telemetry
TELEMETRY_ENABLED=true
TELEMETRY_ENDPOINT=http://localhost:4317

# Database (for production)
DATABASE_URL=sqlite:///./data/aios.db

# Redis (for caching and sessions)
REDIS_URL=redis://localhost:6379

# CORS
AIOS_CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# Plugin Marketplace
PLUGIN_MARKETPLACE_URL=https://plugins.aios.dev

# Development
AIOS_ENV=development
AIOS_DEBUG=true
